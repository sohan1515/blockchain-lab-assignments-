# Example Environment Variables
# Copy this file to .env and fill in your actual values

# Sepolia Testnet RPC URL (from Infura, Alchemy, etc.)
# Get free key from: https://infura.io or https://www.alchemy.com
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_INFURA_KEY

# Your wallet private key (from MetaMask)
# ⚠️ NEVER commit real private keys to git!
# Only use test wallets with small amounts
PRIVATE_KEY=your_private_key_here_only_for_testnet

# Etherscan API key (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Network to deploy to
NETWORK=localhost
